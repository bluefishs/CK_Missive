# =============================================================================
# 乾坤測繪公文管理系統 - 環境變數範例檔
# =============================================================================
# 📝 說明：請複製此檔案為 .env 並填入實際的設定值
# ⚠️ 警告：.env 檔案不應提交至版本控制
# =============================================================================

# --- 🏷️ 專案基本資訊 ---
COMPOSE_PROJECT_NAME=ck_missive
PROJECT_VERSION=3.1
ENVIRONMENT=development
NODE_ENV=development
DEVELOPMENT_MODE=true

# --- 🐳 Docker 服務端口配置 ---
# 前端
FRONTEND_HOST_PORT=3000
FRONTEND_CONTAINER_PORT=80
VITE_PORT=3000

# 後端
BACKEND_HOST_PORT=8001
BACKEND_CONTAINER_PORT=8000

# 資料庫
POSTGRES_HOST_PORT=5434
POSTGRES_CONTAINER_PORT=5432

# 管理工具
ADMINER_HOST_PORT=8080
ADMINER_CONTAINER_PORT=8080

# Redis 快取
REDIS_HOST_PORT=6380
REDIS_CONTAINER_PORT=6379

# --- 🗄️ 資料庫配置 (必填) ---
POSTGRES_USER=ck_user
POSTGRES_PASSWORD=YOUR_SECURE_PASSWORD_HERE  # Phase 1: 可改由 secrets/postgres_password.txt 提供
POSTGRES_DB=ck_documents
POSTGRES_HOST=localhost
DATABASE_URL=postgresql://ck_user:YOUR_SECURE_PASSWORD_HERE@localhost:5434/ck_documents

# Redis 配置
REDIS_HOST=localhost
REDIS_URL=redis://localhost:6380/0

# --- 🔐 安全設定 (生產環境必須修改) ---
# 使用 openssl rand -hex 32 生成安全金鑰
SECRET_KEY=YOUR_SECRET_KEY_HERE_GENERATE_WITH_OPENSSL
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
# MCP Server 服務令牌 (v1.75.0)，用於 Agent sync API 認證
# 使用 openssl rand -hex 32 生成，未設定時停用服務令牌認證
MCP_SERVICE_TOKEN=

# --- 🌐 CORS 與 API 設定 ---
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
VITE_API_BASE_URL=http://localhost:8001
VITE_API_URL=http://localhost:8001

# --- 🔍 開發模式設定 ---
DEBUG=false
DATABASE_ECHO=false
LOG_LEVEL=INFO
# ⚠️ 生產環境必須設為 false
AUTH_DISABLED=false

# --- 🔐 CK SSO Bridge (ADR-0001 / CK_Website#0001) ---
# 員工從 www.cksurvey.tw 登入後跨域 SSO 進公文系統。
# 「加成式」並存，不取代任何既有認證（內網 IP / Google / LINE 完全保留）。
# 灰度上線：先設 false 部署 → 觀察一天 → 改 true 啟用
CK_SSO_ENABLED=false
# 與 Cloudflare Pages JWT_SECRET 完全相同的 HMAC 密鑰（HS256, iss=cksurvey.tw）
# 取得：到 Cloudflare Dashboard → ck-website → Variables and Secrets 看 JWT_SECRET 值
# 若無法直接看到，請改成生產用密碼管理器存的那組
CK_SSO_JWT_SECRET=

# --- 📧 Google OAuth 設定 (選填) ---
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:3000/auth/callback
GOOGLE_CALENDAR_ID=primary
GOOGLE_CREDENTIALS_PATH=./GoogleCalendarAPIKEY.json

# Google OAuth 安全設定
GOOGLE_ALLOWED_DOMAINS=
AUTO_ACTIVATE_NEW_USER=false
DEFAULT_USER_ROLE=user

# --- 📧 Email / SMTP 設定 (選填) ---
# 未設定時系統以開發模式模擬寄信（不實際發送）
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# --- 📱 前端特定設定 ---
VITE_GOOGLE_CLIENT_ID=${GOOGLE_CLIENT_ID}
VITE_AUTH_DISABLED=${AUTH_DISABLED}
# HMR 區網存取（可選，設定後允許同網段裝置存取開發伺服器）
# VITE_DEV_HOST=192.168.x.x
# VITE_DEV_ORIGIN=http://192.168.x.x:3000

# --- 🤖 AI 服務設定 (v1.37.0) ---
# Groq API (免費額度: 30 req/min, 14,400/day)
# 申請: https://console.groq.com/
GROQ_API_KEY=
AI_ENABLED=true
AI_DEFAULT_MODEL=llama-3.3-70b-versatile

# Synthesis model override (2026-04-24 Qwen 零成本整合，docs/evaluations/qwen3-6-27b-hermes-primary.md)
# 未設時預設 llama-3.3-70b-versatile（backward compat）
# 欲切換到 Qwen3-32B（繁中 + agentic 首選，Groq free tier）：SYNTHESIS_MODEL=qwen/qwen3-32b
# SYNTHESIS_MODEL=qwen/qwen3-32b

# Ollama (本地備援，可選)
OLLAMA_BASE_URL=http://localhost:11434
# v5.9.4: qwen2.5:7b 繁中優於 gemma4:e2b；欲切回設為 gemma4:e2b
OLLAMA_MODEL=qwen2.5:7b

# --- 🚩 Feature Flags (v1.44.0) ---
# pgvector 語意搜尋（需要 PostgreSQL pgvector 擴展 + Python pgvector 套件）
# 啟用前：1) pip install pgvector  2) CREATE EXTENSION vector;  3) alembic upgrade head
PGVECTOR_ENABLED=false
# MFA 多因素認證（需要 pyotp + qrcode 套件）
# 啟用前：pip install pyotp qrcode[pil]
MFA_ENABLED=false

# --- 🪟 Windows 編碼設定 ---
# 防止 subprocess / 標準輸出在 Windows cp950 環境下崩潰
PYTHONUTF8=1
PYTHONIOENCODING=utf-8

# --- 📊 監控與日誌 ---
LOG_FILE=./logs/app.log
LOG_MAX_SIZE_MB=10
LOG_BACKUP_COUNT=5

# --- 🚀 效能設定 ---
POOL_SIZE=5
MAX_OVERFLOW=10
POOL_RECYCLE=300
# SQL 查詢超時（毫秒），防止單一查詢無限等待
STATEMENT_TIMEOUT=30000

# --- 🛡️ API 速率限制 ---
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_DAY=10000

# --- 🗂️ 附件儲存路徑 ---
ATTACHMENT_STORAGE_PATH=uploads

# --- ☁️ Cloudflare Tunnel（ADR-0015 / ADR-0016）---
# Dashboard 建立 tunnel 後取得的 token（32+ 字元 base64）
# ecosystem.config.js 偵測到此變數會自動啟 cloudflared PM2 服務
CF_TUNNEL_TOKEN=

# 公網 smoke test 用；設定後會啟用 tests/integration/test_public_exposure_smoke.py
# 平台級多專案規劃：missive / lvrland / pile
MISSIVE_PUBLIC_URL=https://missive.cksurvey.tw

# --- 👻 Shadow Logger（ADR-0014 Hermes 遷移基線）---
SHADOW_ENABLED=1
SHADOW_SAMPLE_RATIO=0.3
SHADOW_RETENTION_DAYS=30
# A/B 比對用 provider 標籤（gemma-hermes / groq-llama）
SHADOW_DEFAULT_PROVIDER=unknown

# =============================================================================
# 📱 LINE Bot — owner 跨通道 + 體感型輸出推送（ADR-0027 / v6.3-v6.7）
# =============================================================================
# 啟用 LINE Bot webhook（POST /api/line/webhook）— 為 false 時整層 disable
LINE_BOT_ENABLED=true
LINE_CHANNEL_SECRET=your_line_channel_secret_here
LINE_CHANNEL_ACCESS_TOKEN=your_line_channel_access_token_here

# ⭐ 體感型輸出主開關（v6.3-v6.7 全部依賴此 key）
# Owner LINE User ID（U + 32 hex chars）— 取得方法：
#   1. LINE 加 Bot 為好友後，發任何訊息給它
#   2. 看 backend log 撈 userId：grep "userId" logs/api/api-out.log | head -1
#   3. 或從 LINE Developer Console → Messaging API → Webhook log 拉
# 缺此 key → 所有體感推送 silent skip（v6.3-v6.7 LINE_ADMIN_USER_ID gate）
LINE_ADMIN_USER_ID=

# 體感推送子開關（預設皆啟用；個別關閉時可設 false）
# v6.3 crystal apply / v6.6 A3 SOUL+rollback / v6.6 B2 22:00 反思 / v6.7 E4 cron 異常
LINE_GROWTH_NOTIFY_ENABLED=true
# v6.3 proactive 警報（截止日 / 預算超支 / 發票催開）
LINE_PROACTIVE_NOTIFY_ENABLED=true

# --- LINE 推播主題合併 + 月度配額守欄（v6.24, 2026-07-08 部署）---
# 免費方案月配額 200 則；各主題 job（吹哨者/自省/cron健康/排程產出/標案訂閱）
# 預設不單推，queue 進 Redis digest buffer，08:00 晨報「昨日主題摘要」尾段
# 一次帶出（line_digest_buffer.py）→ 常規 1 則/日/管理員。
# 月度軟上限：每次 push 前 Redis 計數，超過即拒推＋LOUD log（0=停用守欄）
LINE_MONTHLY_SOFT_CAP=185
# 恢復個別即時單推（吃配額，僅除錯/特殊需求時開）
SELF_REFLECTION_LINE_PUSH_ENABLED=false
TENDER_SUB_LINE_REALTIME=false
# 既有減量 gate（v6.22 第一波）：吹哨者/巡檢/標案推薦即時推
PROACTIVE_LINE_PUSH_ENABLED=false
PIPELINE_LINE_PUSH_ENABLED=false
TENDER_LINE_PUSH_ENABLED=false

# LINE Login（公網 OAuth）
LINE_LOGIN_CHANNEL_ID=
LINE_LOGIN_CHANNEL_SECRET=
LINE_LOGIN_REDIRECT_URI=https://missive.cksurvey.tw/auth/line/callback

# =============================================================================
# 📨 Telegram Bot — admin push 備援（ADR-0027 個人號 4/21 封禁後降為備援）
# =============================================================================
TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_ENABLED=true
# 個人號 push 已封禁，預設 false；需要備援時才設 true
TELEGRAM_ADMIN_PUSH_ENABLED=false
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_SECRET=

# =============================================================================
# 📋 安全檢查清單 (生產部署前確認):
#
# [ ] SECRET_KEY 已設定為強隨機值
# [ ] POSTGRES_PASSWORD 已設定為強密碼
# [ ] AUTH_DISABLED=false
# [ ] DEBUG=false
# [ ] DEVELOPMENT_MODE=false
# [ ] GOOGLE_ALLOWED_DOMAINS 已設定 (如果使用 Google OAuth)
# [ ] AUTO_ACTIVATE_NEW_USER=false
# [ ] CORS_ORIGINS 僅包含允許的網域
# =============================================================================
