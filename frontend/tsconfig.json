{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": [
      "ES2020",
      "DOM",
      "DOM.Iterable"
    ],
    "module": "ESNext",
    "skipLibCheck": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "exactOptionalPropertyTypes": false,  // 關閉: 與 Ant Design 型別不相容
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,  // 關閉: 與 Vite import.meta.env 不相容
    "noUncheckedIndexedAccess": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"],
      "@/components/*": ["src/components/*"],
      "@/pages/*": ["src/pages/*"],
      "@/services/*": ["src/services/*"],
      "@/types/*": ["src/types/*"],
      "@/utils/*": ["src/utils/*"],
      "@/hooks/*": ["src/hooks/*"],
      "@/api/*": ["src/api/*"],
      "@/config/*": ["src/config/*"],
      "@/store/*": ["src/store/*"],
      "@ck-shared/ui-components": ["../../shared-modules/ui-components/index.ts"],
      "@ck-shared/ui-components/*": ["../../shared-modules/ui-components/*"]
    }
  },
  "include": [
    "src",
    "../../shared-modules/ui-components/index.ts",
    "../../shared-modules/ui-components/hooks",
    "../../shared-modules/ui-components/components/index.ts",
    "../../shared-modules/ui-components/components/responsive",
    "../../shared-modules/ui-components/components/MarkdownRenderer.tsx",
    "../../shared-modules/ui-components/components/MermaidBlock.tsx",
    "../../shared-modules/ui-components/components/MermaidDiagram.tsx"
  ],
  "references": [
    {
      "path": "./tsconfig.node.json"
    }
  ]
}