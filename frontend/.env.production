# 公網生產環境配置（missive.cksurvey.tw）
# Vite build --mode production 時自動載入此檔案

# API URL 留空 → 前端走相對路徑 /api（同 origin，CF Tunnel 統一入口）
VITE_API_BASE_URL=

# 🔒 公網必須啟用認證
VITE_AUTH_DISABLED=false

# Google OAuth Client ID
VITE_GOOGLE_CLIENT_ID=482047826162-c91akhidlog5kheed42b8cfqv2g2qls5.apps.googleusercontent.com

# LINE Login Channel ID
VITE_LINE_LOGIN_CHANNEL_ID=
