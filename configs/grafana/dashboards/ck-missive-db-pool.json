{
  "dashboard": {
    "title": "CK Missive — DB Pool & Query Performance",
    "uid": "ck-missive-db-pool",
    "tags": ["ck-missive", "database", "postgres"],
    "timezone": "Asia/Taipei",
    "refresh": "30s",
    "schemaVersion": 38,
    "panels": [
      {
        "title": "Pool Connection Status",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          { "expr": "db_pool_active", "legendFormat": "active (checked-out)" },
          { "expr": "db_pool_checkedin", "legendFormat": "idle (checked-in)" },
          { "expr": "db_pool_size", "legendFormat": "total size" }
        ]
      },
      {
        "title": "Pool Overflow Active",
        "type": "stat",
        "gridPos": { "x": 12, "y": 0, "w": 6, "h": 8 },
        "targets": [{ "expr": "db_pool_overflow_active" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      },
      {
        "title": "Pool Timeouts (15m rate)",
        "type": "stat",
        "gridPos": { "x": 18, "y": 0, "w": 6, "h": 8 },
        "targets": [{ "expr": "rate(db_pool_timeout_total[15m])" }],
        "fieldConfig": {
          "defaults": {
            "unit": "reqps",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "red", "value": 0.001 }
              ]
            }
          }
        }
      },
      {
        "title": "Checkout Rate (5m)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 12, "h": 8 },
        "targets": [
          { "expr": "rate(db_pool_checkout_total[5m])", "legendFormat": "checkouts/s" },
          { "expr": "rate(db_pool_overflow_total[5m])", "legendFormat": "overflow triggers/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } }
      },
      {
        "title": "Query Duration p95 / p99",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 8, "w": 12, "h": 8 },
        "targets": [
          { "expr": "histogram_quantile(0.95, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
          { "expr": "histogram_quantile(0.99, sum by (le) (rate(db_query_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "title": "Slow Query Rate (> 1s)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 16, "w": 24, "h": 8 },
        "targets": [
          { "expr": "rate(db_slow_query_total[5m])", "legendFormat": "slow queries/s" }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } }
      }
    ]
  }
}
