{
  "dashboard": {
    "title": "CK Missive — HTTP Traffic",
    "uid": "ck-missive-http",
    "tags": ["ck-missive", "http", "api"],
    "timezone": "Asia/Taipei",
    "refresh": "30s",
    "schemaVersion": 38,
    "panels": [
      {
        "title": "Request Rate (rps, by path)",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum by (path) (rate(http_requests_total[5m]))",
            "legendFormat": "{{path}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps" } }
      },
      {
        "title": "Error Rate (5xx, by path)",
        "type": "timeseries",
        "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "sum by (path) (rate(http_requests_total{status_code=~\"5..\"}[5m]))",
            "legendFormat": "{{path}}"
          }
        ],
        "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } }
      },
      {
        "title": "Latency p50 / p95 / p99",
        "type": "timeseries",
        "gridPos": { "x": 0, "y": 8, "w": 16, "h": 8 },
        "targets": [
          { "expr": "histogram_quantile(0.50, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p50" },
          { "expr": "histogram_quantile(0.95, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p95" },
          { "expr": "histogram_quantile(0.99, sum by (le) (rate(http_request_duration_seconds_bucket[5m])))", "legendFormat": "p99" }
        ],
        "fieldConfig": { "defaults": { "unit": "s" } }
      },
      {
        "title": "Active Requests",
        "type": "stat",
        "gridPos": { "x": 16, "y": 8, "w": 8, "h": 8 },
        "targets": [{ "expr": "http_requests_active" }],
        "fieldConfig": {
          "defaults": {
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 20 },
                { "color": "red", "value": 40 }
              ]
            }
          }
        }
      },
      {
        "title": "Top 10 Endpoints by Requests (15m)",
        "type": "table",
        "gridPos": { "x": 0, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "topk(10, sum by (path) (increase(http_requests_total[15m])))",
            "format": "table",
            "instant": true
          }
        ]
      },
      {
        "title": "Error Rate (% of requests, 5m)",
        "type": "stat",
        "gridPos": { "x": 12, "y": 16, "w": 12, "h": 8 },
        "targets": [
          {
            "expr": "100 * sum(rate(http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(http_requests_total[5m]))",
            "legendFormat": "error rate"
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": 0 },
                { "color": "yellow", "value": 2 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        }
      }
    ]
  }
}
